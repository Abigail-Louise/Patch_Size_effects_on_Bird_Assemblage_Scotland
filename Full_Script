### 5. SINGLE_SEASON OCCUPANCY MODELS ----

species_list <- unique(det_long$scientific_name)

results <- list()

for(sp in species_list){
  
  sp_data <- det_long %>%
    dplyr::filter(scientific_name == sp)
  
  y <- sp_data %>%
    dplyr::select(site, survey, detected) %>%
    tidyr::pivot_wider(names_from = survey, values_from = detected) %>%
    dplyr::arrange(site) %>%
    dplyr::select(-site) %>%
    as.matrix()
  
  dim(y)
  # Should be 20 x 3
  
  # Detection covariates
  obsCovs <- list(
    temp = temp_mat,
    wind = wind_mat,
    rain = rain_mat)
  
  # Create unmarked frame
  umf <- unmarkedFrameOccu(
    y = y,
    siteCovs = site_covs_scaled,
    obsCovs = list(
      temp = temp_mat,
      wind = wind_mat,
      rain = rain_mat))
  
  # Fit occupancy model
  model <- occu(
    ~ temp + wind + rain ~ log_patch_size + elevation_m + distance_to_nearest_patch_m + forest_cover_percent_in_1km_buffer_exc_target_patch,
    data = umf)
  
  results[[sp]] <- model}

# MacKenzie and Bailey goodness-of-fit for single-season occupancy model
