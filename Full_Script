era_acc  <- rast("your_path")

# Site coordinates
sites <- data.frame(
  lat = c(
    56.155196,56.064907,56.041572,56.061413,56.066086,
    55.934878,55.908225,55.887171,55.996752,55.962135,
    56.003955,56.020566,56.043662,56.136994,55.910760,
    56.140979,56.326588,56.321599,56.269253,56.139103),
  lon = c(
    -3.592279,-3.547279,-3.447078,-3.348713,-3.290733,
    -3.008563,-2.980734,-2.826877,-2.787386,-2.845098,
    -3.583008,-3.768519,-3.898148,-3.914772,-3.654204,
    -3.797309,-3.743630,-3.570111,-3.403390,-3.241825))

sites_vect <- vect(sites, geom=c("lon","lat"), crs="EPSG:4326")

# Extract ERA5 values
weather_inst <- terra::extract(era_inst, sites_vect)[,-1]
weather_acc  <- terra::extract(era_acc, sites_vect)[,-1]


# Temperature
temp <- weather_inst[, grep("t2m", names(weather_inst))] - 273.15

temp_long <- as.data.frame(temp) %>%
  mutate(site = 1:20) %>%
  pivot_longer(-site, names_to="time", values_to="temp")

temp_long$date <- as.Date(as.POSIXct(
  as.numeric(sub(".*=", "", temp_long$time)),
  origin="1970-01-01", tz="UTC"))

temp_daily <- temp_long %>%
  group_by(site, date) %>%
  summarise(temp = mean(temp, na.rm=TRUE), .groups="drop")


# Wind speed

u <- as.matrix(weather_inst[, grep("u10", names(weather_inst))])
v <- as.matrix(weather_inst[, grep("v10", names(weather_inst))])

wind <- sqrt(u^2 + v^2)

wind_long <- as.data.frame(wind) %>%
  mutate(site = 1:20) %>%
  pivot_longer(-site, names_to="time", values_to="wind")

wind_long$date <- as.Date(as.POSIXct(
  as.numeric(sub(".*=", "", wind_long$time)),
  origin="1970-01-01", tz="UTC"))

wind_daily <- wind_long %>%
  group_by(site, date) %>%
  summarise(wind = mean(wind, na.rm=TRUE), .groups="drop")


# Rainfall

rain <- weather_acc[, grep("tp", names(weather_acc))] * 1000

rain_long <- as.data.frame(rain) %>%
  mutate(site = 1:20) %>%
  pivot_longer(-site, names_to="time", values_to="rain")

rain_long$date <- as.Date(as.POSIXct(
  as.numeric(sub(".*=", "", rain_long$time)),
  origin="1970-01-01", tz="UTC"))

rain_daily <- rain_long %>%
  group_by(site, date) %>%
  summarise(rain = sum(rain, na.rm=TRUE), .groups="drop")


# Survey dates

survey_dates <- data.frame(
  site = 1:20,
  start = as.Date(c(
    rep("2025-07-05",5),
    rep("2025-07-10",5),
    rep("2025-07-11",5),
    rep("2025-07-09",5))))

survey_dates$day1 <- survey_dates$start
survey_dates$day2 <- survey_dates$start + 1
survey_dates$day3 <- survey_dates$start + 2

survey_long <- survey_dates %>%
