find_cross <- function(coefs){
  
  patch_grid <- seq(min(psi_long$log_patch_size),
                    max(psi_long$log_patch_size),
                    length.out = 1000)
  
  # predicted values for generalists
  gen <- coefs["(Intercept)"] +
    coefs["log_patch_size"] * patch_grid
  
  # predicted values for specialists
  spec <- coefs["(Intercept)"] +
    coefs["guildspecialist"] +
    (coefs["log_patch_size"] +
       coefs["log_patch_size:guildspecialist"]) * patch_grid
  
  gen <- plogis(gen)
  spec <- plogis(spec)
  
  diff <- spec - gen
  
  cross <- which(diff[-1] * diff[-length(diff)] < 0)
  
  if(length(cross) == 0) return(NA)
  
  patch_grid[cross[1]]}

