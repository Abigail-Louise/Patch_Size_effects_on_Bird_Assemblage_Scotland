for(i in seq_along(results)) {
  
  gof <- tryCatch(
    mb.gof.test(results[[i]], nsim = 1000),
    error = function(e) return(NULL)
  )
  
  if(!is.null(gof)) {
    
    # try multiple possible locations safely
    pval <- if(!is.null(gof$p.value)) gof$p.value else NA
    
    chat <- NA
    if(!is.null(gof$chisq) && !is.null(gof$df)) {
      chat <- gof$chisq / gof$df
    }
    
    gof_summary$p_value[i] <- pval
    gof_summary$chat[i] <- chat
  }
}

